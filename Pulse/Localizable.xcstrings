          }
        }
      }
    },
    "reflection.question.1" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcher Moment heute hat sich am lebendigsten angefühlt – und was hat ihn möglich gemacht?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What single moment today felt most alive — and what made it possible?"
          }
        }
      }
    },
    "reflection.question.2" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wo hast du heute deine beste Energie investiert – und war es das wert?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Where did you give your best energy today — and was it worth it?"
          }
        }
      }
    },
    "reflection.question.3" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welche Emotion hat dich heute am stärksten begleitet – und was wollte sie dir sagen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What emotion showed up most today — and what was it trying to tell you?"
          }
        }
      }
    },
    "reflection.question.4" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn der heutige Tag ein Kapitel in deiner Lebensgeschichte wäre – welchen Titel würdest du ihm geben?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If today were a chapter in your life story, what title would you give it?"
          }
        }
      }
    },
    "reflection.question.5" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welchen Moment würdest du heute anders gestalten – und was hält dich davon ab, es beim nächsten Mal zu tun?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Which moment would you handle differently — and what's stopping you from doing so next time?"
          }
        }
      }
    },
    "reflection.question.6" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was oder wer hat heute deine Energie gezogen – und was oder wer hat sie wieder aufgeladen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Who or what drained your energy today — and who or what restored it?"
          }
        }
      }
    },
    "reflection.question.7" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was hat dir der heutige Tag über das gezeigt, was dir wirklich wichtig ist?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What did today reveal about what truly matters to you?"
          }
        }
      }
    },
    "reflection.question.8" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wo hast du dich heute zurückgehalten – und was hat dich davon abgehalten, vollständig präsent zu sein?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Where did you hold back today — and what kept you from being fully present?"
          }
        }
      }
    },
    "reflection.question.9" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wofür bist du heute am dankbarsten – und warum bedeutet es dir etwas?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What are you most grateful for today — and why does it matter to you?"
          }
        }
      }
    },
    "reflection.question.10" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hat dich der heutige Tag der Person nähergebracht, die du sein möchtest – oder eher von ihr entfernt?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Did today move you closer to — or further from — the person you want to become?"
          }
        }
      }
    },
    "reflection.question.11" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was hat dir heute Freude gemacht – und wie kannst du davon mehr in deinen Alltag bringen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What brought you genuine joy today — and how could you invite more of that into your life?"
          }
        }
      }
    },
    "reflection.question.12" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wann hast du heute das Gefühl gehabt, ganz du selbst zu sein – und wann nicht?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When did you feel most like yourself today — and when did you feel furthest from it?"
          }
        }
      }
    },
    "reflection.question.13" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welche Entscheidung hast du heute getroffen, auf die du stolz bist – und was hat dich dazu gebracht?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What decision did you make today that you're proud of — and what drove it?"
          }
        }
      }
    },
    "reflection.question.14" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was hat dir heute Sorgen bereitet – und wie viel davon liegt wirklich in deiner Kontrolle?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What weighed on you today — and how much of it is actually within your control?"
          }
        }
      }
    },
    "reflection.question.15" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie gut hast du heute auf deine eigenen Bedürfnisse geachtet – und was brauchst du mehr davon?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How well did you honour your own needs today — and what do you need more of?"
          }
        }
      }
    },
    "reflection.question.16" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was hat dich heute überrascht – und was sagt das über deine Erwartungen aus?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What surprised you today — and what does that reveal about your expectations?"
          }
        }
      }
    },
    "reflection.question.17" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welchem Menschen bist du heute begegnet, der einen Eindruck bei dir hinterlassen hat – und weshalb?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Who made an impression on you today — and what did that person stir in you?"
          }
        }
      }
    },
    "reflection.question.18" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wo hast du heute mutig gehandelt – auch wenn es niemand bemerkt hat?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Where did you act with courage today — even if no one noticed?"
          }
        }
      }
    },
    "reflection.question.19" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was hast du heute über dich selbst gelernt, das du noch nicht wusstest?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What did you learn about yourself today that you didn't know before?"
          }
        }
      }
    },
    "reflection.question.20" : {
      "comment" : "Coaching question shown in the daily reflection sheet when no summary has been written yet.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du deinem morgigen Ich eine Botschaft aus diesem Tag mitgeben könntest – was wäre das?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you could send one message to tomorrow's version of you, based on today, what would it say?"
          }
        }
      }
    },
